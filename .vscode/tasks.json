{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build and run cpp",
            "type": "shell",
            "command": "cmd.exe",
            "args": [
                "/c",
                "g++ \"${file}\" -o \"${fileBasenameNoExtension}.exe\" && \"${fileBasenameNoExtension}.exe\""
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
    "reveal": "silent",
    "panel": "shared",
    "showReuseMessage": false,
    "clear": true
},

            "problemMatcher": "$gcc"
        }
    ]
}
